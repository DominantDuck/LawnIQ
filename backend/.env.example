# SwiftQuote. backend environment

# Server Configuration
PORT=3001
NODE_ENV=development

# Vercel multi-service only: must match backend routePrefix in root vercel.json (no trailing slash)
# EXPRESS_ROUTE_PREFIX=/_/backend

# Google Maps (satellite imagery)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# CORS Settings (comma-separated in production; ignored in development)
FRONTEND_URL=http://localhost:5173

# API Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_ANALYSIS_PER_DAY=1000

# Image Processing
MAX_IMAGE_SIZE_MB=10
SUPPORTED_IMAGE_FORMATS=jpeg,jpg,png,webp