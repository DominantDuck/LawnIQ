# LawnIQ Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== GOOGLE MAPS API =====
# Required for maps functionality (get from Google Cloud Console)
GOOGLE_MAPS_API_KEY=AIza_your_google_maps_api_key_here

# ===== DATABASE =====
# Required for CRM functionality (get from Vercel Postgres dashboard)
POSTGRES_URL=postgresql://username:password@host:port/database

# ===== AUTHENTICATION =====
# Required for CRM user authentication (generate a secure random string)
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# ===== API PROTECTION =====
# Optional: protect GET /api/stats (generate a random secret)
STATS_API_SECRET=your_stats_secret_here

# ===== BACKEND CONFIGURATION =====
# Backend server settings (when running Express backend separately)
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3002

# API rate limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_ANALYSIS_PER_DAY=1000

# Image processing settings
MAX_IMAGE_SIZE_MB=10
SUPPORTED_IMAGE_FORMATS=jpeg,jpg,png,webp

# ===== OPENAI API =====
# Optional: for AI-powered features
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ===== LEGACY BACKEND PROXY =====
# Uncomment to proxy all /api calls to Express backend
# USE_EXPRESS_BACKEND=true
# BACKEND_URL=http://127.0.0.1:3001