# Required for maps (same key as Google Cloud Maps JavaScript API)
GOOGLE_MAPS_API_KEY=

# Optional: Vercel Postgres / Neon — enables saving each address search + /api/stats
# POSTGRES_URL=

# Optional: protect GET /api/stats (send header x-stats-secret)
# STATS_API_SECRET=

# Legacy: proxy all /api to Express
# USE_EXPRESS_BACKEND=true
# BACKEND_URL=http://127.0.0.1:3001
